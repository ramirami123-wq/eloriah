    "custom_liquid_zebLLh": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n.nuvapore-compare {\n  width: 100%;\n  max-width: 900px;\n  margin: 25px auto;\n  border-collapse: collapse;\n  font-family: Arial, sans-serif;\n  font-size: 15px;\n  border-radius: 14px;\n  overflow: hidden;\n  box-shadow: 0 4px 18px rgba(223,115,144,.15);\n}\n\n.nuvapore-compare th {\n  background: #df7390;\n  color: #fff;\n  padding: 15px 10px;\n  text-align: center;\n}\n\n.nuvapore-compare td {\n  padding: 14px 10px;\n  text-align: center;\n  border-bottom: 1px solid #f2d4dc;\n}\n\n.nuvapore-compare td:first-child {\n  text-align: left;\n  font-weight: 600;\n  color: #444;\n}\n\n.nuvapore-compare tr:nth-child(even) {\n  background: #fff7f9;\n}\n\n.nuvapore-yes {\n  color: #df7390;\n  font-weight: 700;\n}\n\n.nuvapore-no {\n  color: #999;\n  font-weight: 700;\n}\n\n@media (max-width:600px){\n  .nuvapore-compare{\n    font-size:13px;\n  }\n\n  .nuvapore-compare th,\n  .nuvapore-compare td{\n    padding:11px 6px;\n  }\n}\n</style>\n\n<table class=\"nuvapore-compare\">\n  <tr>\n    <th>Benefits</th>\n    <th>Nuvapore</th>\n    <th>Others</th>\n  </tr>\n\n  <tr>\n    <td>Adjustable Suction Levels</td>\n    <td class=\"nuvapore-yes\">✔ Yes</td>\n    <td class=\"nuvapore-no\">✖ No</td>\n  </tr>\n\n  <tr>\n    <td>3 Skin Modes</td>\n    <td class=\"nuvapore-yes\">✔ Yes</td>\n    <td class=\"nuvapore-no\">✖ No</td>\n  </tr>\n\n  <tr>\n    <td>Multiple Suction Heads</td>\n    <td class=\"nuvapore-yes\">✔ Yes</td>\n    <td class=\"nuvapore-no\">✖ No</td>\n  </tr>\n\n  <tr>\n    <td>Rechargeable & Cordless</td>\n    <td class=\"nuvapore-yes\">✔ Yes</td>\n    <td class=\"nuvapore-no\">✖ No</td>\n  </tr>\n\n  <tr>\n    <td>Portable Design</td>\n    <td class=\"nuvapore-yes\">✔ Yes</td>\n    <td class=\"nuvapore-no\">✖ No</td>\n  </tr>\n\n  <tr>\n    <td>Helps Remove the Look of Blackheads</td>\n    <td class=\"nuvapore-yes\">✔ Yes</td>\n    <td class=\"nuvapore-no\">✖ No</td>\n  </tr>\n\n  <tr>\n    <td>Suitable for Weekly Home Use</td>\n    <td class=\"nuvapore-yes\">✔ Yes</td>\n    <td class=\"nuvapore-no\">✖ No</td>\n  </tr>\n</table>",
        "full_width": false,
        "show_divider": false,
        "padding_top": 36,
        "padding_bottom": 36
      }
    },
    "custom_liquid_3DxFmH": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n.faq-section{\nmax-width:900px;\nmargin:40px auto;\nfont-family:Arial,sans-serif;\n}\n.faq-section details{\nborder-bottom:1px solid #e5e5e5;\npadding:16px 0;\n}\n.faq-section summary{\nlist-style:none;\ncursor:pointer;\nfont-size:17px;\nfont-weight:600;\ndisplay:flex;\njustify-content:space-between;\nalign-items:center;\n}\n.faq-section summary::-webkit-details-marker{\ndisplay:none;\n}\n.faq-section summary::after{\ncontent:\"+\";\nfont-size:24px;\nfont-weight:400;\ntransition:.2s;\n}\n.faq-section details[open] summary::after{\ncontent:\"−\";\n}\n.faq-section .answer{\nmargin-top:12px;\nfont-size:15px;\nline-height:1.7;\ncolor:#666;\n}\n</style>\n\n<div class=\"faq-section\">\n\n<details>\n<summary>How often should I use Nuvapore?</summary>\n<div class=\"answer\">\nFor best results, use Nuvapore <strong>1–2 times per week</strong>. Avoid excessive use to help keep your skin comfortable.\n</div>\n</details>\n\n<details>\n<summary>Is Nuvapore suitable for all skin types?</summary>\n<div class=\"answer\">\nYes! Nuvapore features <strong>Normal, Oily, and Dry</strong> skin modes with adjustable suction levels, allowing you to customize your skincare routine.\n</div>\n</details>\n\n<details>\n<summary>Does it come with different suction heads?</summary>\n<div class=\"answer\">\nYes. Nuvapore includes multiple interchangeable suction heads designed for different facial areas and skincare needs.\n</div>\n</details>\n\n<details>\n<summary>Can I use it on active acne?</summary>\n<div class=\"answer\">\nNo. Avoid using Nuvapore on active acne, irritated skin, sunburn, wounds, or directly under the eyes.\n</div>\n</details>\n\n<details>\n<summary>How should I prepare my skin before using it?</summary>\n<div class=\"answer\">\nStart with a clean face. For best results, use the device after a warm shower, facial steamer, or warm towel to help prepare the skin before treatment.\n</div>\n</details>\n\n<details>\n<summary>Is it rechargeable?</summary>\n<div class=\"answer\">\nYes! Nuvapore is USB rechargeable, cordless, and portable, making it convenient for both home use and travel.\n</div>\n</details>\n\n</div>",
        "full_width": false,
        "show_divider": false,
        "padding_top": 36,
        "padding_bottom": 36
      }
    },
